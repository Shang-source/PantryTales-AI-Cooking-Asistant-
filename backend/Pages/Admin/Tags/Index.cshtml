@page
@model backend.Pages.Admin.Tags.IndexModel
@{
    ViewData["Title"] = "Tags";
}

<div
    x-data="{ showCreateModal: false, showEditModal: false, editId: null, editName: '', editDisplayName: '', editType: '', editColor: '#000000', editIcon: '', openEditModal(button) { const data = button.dataset; this.editId = parseInt(data.tagId); this.editName = data.tagName || ''; this.editDisplayName = data.tagDisplayName || ''; this.editType = data.tagType || ''; this.editColor = data.tagColor || '#000000'; this.editIcon = data.tagIcon || ''; this.showEditModal = true; } }">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
        <div>
            <h2 class="text-2xl font-bold text-gray-900">Tags</h2>
            <p class="text-sm text-gray-600 mt-1">Manage tags for categorizing inventory and recipes</p>
        </div>
        <button @@click="showCreateModal = true"
            class="inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-md transition-colors">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Add Tag
        </button>
    </div>

    <!-- Messages -->
    @if (TempData["Error"] != null)
    {
        <div class="mb-4 flex items-center gap-3 p-4 bg-red-50 border border-red-200 rounded-lg">
            <svg class="w-5 h-5 text-red-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z"
                    clip-rule="evenodd" />
            </svg>
            <span class="text-sm text-red-800">@TempData["Error"]</span>
        </div>
    }

    <!-- Data Table -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full">
                <thead>
                    <tr class="border-b border-gray-200">
                        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type
                        </th>
                        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                            Display Name</th>
                        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                            Internal Name</th>
                        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                            Metadata</th>
                        <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
                            Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    @foreach (var tag in Model.Tags)
                    {
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-4 py-3 text-sm">
                                <span
                                    class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                                    @tag.Type
                                </span>
                            </td>
                            <td class="px-4 py-3 text-sm font-medium text-gray-900">@tag.DisplayName</td>
                            <td class="px-4 py-3 text-sm font-mono text-gray-600">@tag.Name</td>
                            <td class="px-4 py-3 text-sm">
                                <div class="flex items-center gap-2">
                                    @if (!string.IsNullOrEmpty(tag.Color))
                                    {
                                        var safeColor = System.Text.RegularExpressions.Regex.IsMatch(tag.Color, "^#[0-9A-Fa-f]{3,6}$") ? tag.Color : "#000000";
                                        <span class="inline-block w-4 h-4 rounded border border-gray-200"
                                            style="background-color: @safeColor"></span>
                                    }
                                    @if (!string.IsNullOrEmpty(tag.Icon))
                                    {
                                        <span class="text-xs text-gray-500">@(tag.Icon)</span>
                                    }
                                </div>
                            </td>
                            <td class="px-4 py-3 text-sm text-right">
                                <button type="button" data-tag-id="@tag.Id"
                                    data-tag-name="@System.Web.HttpUtility.JavaScriptStringEncode(tag.Name)"
                                    data-tag-display-name="@System.Web.HttpUtility.JavaScriptStringEncode(tag.DisplayName)"
                                    data-tag-type="@System.Web.HttpUtility.JavaScriptStringEncode(tag.Type)"
                                    data-tag-color="@System.Web.HttpUtility.JavaScriptStringEncode(tag.Color ?? "#000000")"
                                    data-tag-icon="@System.Web.HttpUtility.JavaScriptStringEncode(tag.Icon ?? "")"
                                    @@click="openEditModal($event.currentTarget)"
                                    class="text-blue-600 hover:text-blue-800 font-medium mr-3">
                                    Edit
                                </button>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@tag.Id"
                                    onsubmit="return confirm('Delete this tag?');" class="inline">
                                    <button type="submit"
                                        class="text-red-600 hover:text-red-800 font-medium">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (!Model.Tags.Any())
        {
            <div class="p-12 text-center">
                <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                </svg>
                <p class="mt-2 text-sm text-gray-500">No tags found. Create your first tag to get started.</p>
            </div>
        }
    </div>

    <!-- Create Modal -->
    <div x-show="showCreateModal" style="display: none;" class="fixed inset-0 z-50 flex items-center justify-center p-4"
        x-cloak>
        <div class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm" @@click="showCreateModal = false"></div>
        <div class="relative bg-white rounded-xl shadow-xl max-w-lg w-full p-6 z-10">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Add New Tag</h3>
            <form method="post" asp-page-handler="Create">
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Tag Type</label>
                        @if (Model.TagTypes.Any())
                        {
                            <select asp-for="NewTag.Type"
                                class="w-full border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border"
                                required>
                                @foreach (var tagType in Model.TagTypes)
                                {
                                    <option value="@tagType.Name">@tagType.DisplayName</option>
                                }
                            </select>
                            <p class="text-xs text-gray-500 mt-1">
                                <a asp-page="/Admin/TagTypes/Index" class="text-blue-600 hover:underline">Manage tag
                                    types</a>
                            </p>
                        }
                        else
                        {
                            <input asp-for="NewTag.Type" placeholder="e.g. Diet, MealType"
                                class="w-full border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border"
                                required />
                            <p class="text-xs text-gray-500 mt-1">
                                No tag types configured. <a asp-page="/Admin/TagTypes/Index"
                                    class="text-blue-600 hover:underline">Create tag types first</a>
                            </p>
                        }
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Display Name</label>
                        <input asp-for="NewTag.DisplayName" placeholder="e.g. Gluten Free"
                            class="w-full border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border"
                            required />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Internal Name (Slug)</label>
                        <input asp-for="NewTag.Name" placeholder="e.g. gluten-free"
                            class="w-full border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border"
                            required />
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Color</label>
                            <input asp-for="NewTag.Color" type="color"
                                class="w-full h-10 border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500 p-1 border" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Icon Name</label>
                            <input asp-for="NewTag.Icon"
                                class="w-full border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border" />
                        </div>
                    </div>
                </div>

                <div class="flex justify-end gap-3 mt-6">
                    <button type="button" @@click="showCreateModal = false"
                        class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-md transition-colors">
                        Cancel
                    </button>
                    <button type="submit"
                        class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-md transition-colors">
                        Create Tag
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Edit Modal -->
    <div x-show="showEditModal" style="display: none;" class="fixed inset-0 z-50 flex items-center justify-center p-4"
        x-cloak>
        <div class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm" @@click="showEditModal = false"></div>
        <div class="relative bg-white rounded-xl shadow-xl max-w-lg w-full p-6 z-10">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Edit Tag</h3>
            <form method="post" asp-page-handler="Edit">
                <input type="hidden" asp-for="EditId" x-model="editId" />

                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Tag Type</label>
                        @if (Model.TagTypes.Any())
                        {
                            <select asp-for="EditTag.Type" x-model="editType"
                                class="w-full border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border"
                                required>
                                @foreach (var tagType in Model.TagTypes)
                                {
                                    <option value="@tagType.Name">@tagType.DisplayName</option>
                                }
                            </select>
                        }
                        else
                        {
                            <input asp-for="EditTag.Type" x-model="editType"
                                class="w-full border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border"
                                required />
                        }
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Display Name</label>
                        <input asp-for="EditTag.DisplayName" x-model="editDisplayName"
                            class="w-full border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border"
                            required />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Internal Name (Slug)</label>
                        <input asp-for="EditTag.Name" x-model="editName"
                            class="w-full border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border"
                            required />
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Color</label>
                            <input asp-for="EditTag.Color" type="color" x-model="editColor"
                                class="w-full h-10 border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500 p-1 border" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Icon Name</label>
                            <input asp-for="EditTag.Icon" x-model="editIcon"
                                class="w-full border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border" />
                        </div>
                    </div>
                </div>

                <div class="flex justify-end gap-3 mt-6">
                    <button type="button" @@click="showEditModal = false"
                        class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-md transition-colors">
                        Cancel
                    </button>
                    <button type="submit"
                        class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-md transition-colors">
                        Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>