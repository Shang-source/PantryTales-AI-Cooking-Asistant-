@page
@model backend.Pages.Admin.Jobs.IndexModel
@{
    ViewData["Title"] = "Background Jobs";
}

<div class="mb-6">
    <div class="mb-6">
        <h2 class="text-2xl font-bold text-gray-900">System Status</h2>
        <p class="text-sm text-gray-600 mt-1">Monitor and trigger background services</p>
    </div>

    <!-- Messages -->
    @if (TempData["Message"] != null)
    {
        <div class="mb-4 flex items-center gap-3 p-4 bg-green-50 border border-green-200 rounded-lg">
            <svg class="w-5 h-5 text-green-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm text-green-800">@TempData["Message"]</span>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="mb-4 flex items-center gap-3 p-4 bg-red-50 border border-red-200 rounded-lg">
            <svg class="w-5 h-5 text-red-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm text-red-800">@TempData["Error"]</span>
        </div>
    }

    <!-- Jobs Table -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full">
                <thead>
                    <tr class="border-b border-gray-200">
                        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Job Name</th>
                        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Last Run</th>
                        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Last Result</th>
                        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Message</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    @foreach (var job in Model.Statuses)
                    {
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-4 py-3 text-sm font-medium text-gray-900">@job.JobName</td>
                            <td class="px-4 py-3 text-sm">
                                @if (job.Status == "Running")
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 animate-pulse">
                                        <span class="w-1.5 h-1.5 bg-blue-600 rounded-full mr-1.5"></span>
                                        Running
                                    </span>
                                }
                                else if (job.Status == "Error")
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                        Error
                                    </span>
                                }
                                else if (job.Status == "Disabled")
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">
                                        Disabled
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                        @job.Status
                                    </span>
                                }
                            </td>
                            <td class="px-4 py-3 text-sm text-gray-600">
                                @if (job.LastRun.HasValue)
                                {
                                    <span>@job.LastRun.Value.ToLocalTime().ToString("g")</span>
                                }
                                else
                                {
                                    <span class="text-gray-400">Never</span>
                                }
                            </td>
                            <td class="px-4 py-3 text-sm">
                                @if (job.LastRunSuccess.HasValue)
                                {
                                    @if (job.LastRunSuccess.Value)
                                    {
                                        <span class="inline-flex items-center text-green-600">
                                            <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                                            </svg>
                                            Success
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center text-red-600" title="@(job.LastError ?? "Unknown error")">
                                            <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                                            </svg>
                                            Failed
                                        </span>
                                    }
                                }
                                else
                                {
                                    <span class="text-gray-400">-</span>
                                }
                            </td>
                            <td class="px-4 py-3 text-sm">
                                <div class="text-gray-600">@(job.Message ?? "-")</div>
                                @if (!string.IsNullOrEmpty(job.LastError))
                                {
                                    <div class="text-red-500 text-xs mt-1 truncate max-w-xs" title="@job.LastError">@job.LastError</div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (!Model.Statuses.Any())
        {
            <div class="p-12 text-center">
                <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <p class="mt-2 text-sm text-gray-500">No job activity recorded yet.</p>
            </div>
        }
    </div>

    <!-- Manual Actions -->
    <div class="mt-8">
        <h3 class="text-lg font-semibold text-gray-900 mb-4">Manual Actions</h3>
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4">
            <form method="post" asp-page-handler="TriggerNormalization" class="inline">
                <button type="submit"
                    class="inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-md transition-colors">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    Run Normalization Batch
                </button>
            </form>
            <p class="text-xs text-gray-500 mt-2">Manually trigger a normalization batch to process pending inventory items.</p>
        </div>
    </div>
</div>
