@page
@using backend.Models
@model backend.Pages.Admin.Recipes.IndexModel
@{
    ViewData["Title"] = "Recipes";
}

<div x-data="{
        showEditModal: false,
        editId: '',
        editTitle: '',
        editDescription: '',
        editType: 1,
        editVisibility: 1,
        editDifficulty: 0,
        openEditModal(button) {
            const data = button.dataset;
            this.editId = data.recipeId;
            this.editTitle = data.recipeTitle || '';
            this.editDescription = data.recipeDescription || '';
            this.editType = parseInt(data.recipeType);
            this.editVisibility = parseInt(data.recipeVisibility);
            this.editDifficulty = parseInt(data.recipeDifficulty);
            this.showEditModal = true;
        }
    }">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
        <div>
            <h2 class="text-2xl font-bold text-gray-900">Recipes</h2>
            <p class="text-sm text-gray-600 mt-1">Manage and moderate recipes (@Model.TotalRecipes total)</p>
        </div>
    </div>

    <!-- Filters -->
    <div class="mb-4 bg-white rounded-lg shadow-sm border border-gray-200 p-4">
        <form method="get" class="flex flex-wrap items-end gap-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Type</label>
                <select name="filterType"
                    class="border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border">
                    <option value="">All Types</option>
                    <option value="@((int)RecipeType.User)" selected="@(Model.FilterType == RecipeType.User)">User</option>
                    <option value="@((int)RecipeType.System)" selected="@(Model.FilterType == RecipeType.System)">System</option>
                    <option value="@((int)RecipeType.Model)" selected="@(Model.FilterType == RecipeType.Model)">Model (AI)</option>
                </select>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Visibility</label>
                <select name="filterVisibility"
                    class="border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border">
                    <option value="">All</option>
                    <option value="@((int)RecipeVisibility.Private)" selected="@(Model.FilterVisibility == RecipeVisibility.Private)">Private</option>
                    <option value="@((int)RecipeVisibility.Public)" selected="@(Model.FilterVisibility == RecipeVisibility.Public)">Public</option>
                </select>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Search</label>
                <input type="text" name="search" value="@Model.Search" placeholder="Search by title..."
                    class="border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border" />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Page Size</label>
                <select name="pageSize"
                    class="border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border">
                    <option value="10" selected="@(Model.PageSize == 10)">10</option>
                    <option value="20" selected="@(Model.PageSize == 20)">20</option>
                    <option value="50" selected="@(Model.PageSize == 50)">50</option>
                    <option value="100" selected="@(Model.PageSize == 100)">100</option>
                </select>
            </div>

            <button type="submit"
                class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-md transition-colors">
                Apply Filters
            </button>

            @if (Model.FilterType.HasValue || Model.FilterVisibility.HasValue || !string.IsNullOrEmpty(Model.Search))
            {
                <a href="/Admin/Recipes"
                    class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-md transition-colors">
                    Clear Filters
                </a>
            }
        </form>
    </div>

    <!-- Messages -->
    @if (TempData["Success"] != null)
    {
        <div class="mb-4 flex items-center gap-3 p-4 bg-green-50 border border-green-200 rounded-lg">
            <svg class="w-5 h-5 text-green-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                    clip-rule="evenodd" />
            </svg>
            <span class="text-sm text-green-800">@TempData["Success"]</span>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="mb-4 flex items-center gap-3 p-4 bg-red-50 border border-red-200 rounded-lg">
            <svg class="w-5 h-5 text-red-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z"
                    clip-rule="evenodd" />
            </svg>
            <span class="text-sm text-red-800">@TempData["Error"]</span>
        </div>
    }

    <!-- Data Table -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full">
                <thead>
                    <tr class="border-b border-gray-200">
                        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Title</th>
                        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Author</th>
                        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
                        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Visibility</th>
                        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Stats</th>
                        <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Featured</th>
                        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Created</th>
                        <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    @foreach (var recipe in Model.Recipes)
                    {
                        <tr class="hover:bg-gray-50 transition-colors">
                            <td class="px-4 py-3">
                                <div class="text-sm font-medium text-gray-900 max-w-xs truncate" title="@recipe.Title">@recipe.Title</div>
                                @if (!string.IsNullOrEmpty(recipe.Description))
                                {
                                    <div class="text-xs text-gray-500 max-w-xs truncate" title="@recipe.Description">@recipe.Description</div>
                                }
                            </td>
                            <td class="px-4 py-3 text-sm text-gray-600">
                                @(recipe.AuthorNickname ?? "—")
                            </td>
                            <td class="px-4 py-3 text-sm">
                                @switch (recipe.Type)
                                {
                                    case RecipeType.User:
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">User</span>
                                        break;
                                    case RecipeType.System:
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">System</span>
                                        break;
                                    case RecipeType.Model:
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">Model</span>
                                        break;
                                }
                            </td>
                            <td class="px-4 py-3 text-sm">
                                @if (recipe.Visibility == RecipeVisibility.Public)
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Public</span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">Private</span>
                                }
                            </td>
                            <td class="px-4 py-3 text-sm text-gray-500">
                                <span title="Likes">@recipe.LikesCount ❤️</span>
                                <span class="ml-2" title="Comments">@recipe.CommentsCount 💬</span>
                                <span class="ml-2" title="Saves">@recipe.SavedCount 📌</span>
                            </td>
                            <td class="px-4 py-3 text-center">
                                @{
                                    var canFeature = recipe.Type == RecipeType.User && recipe.Visibility == RecipeVisibility.Public;
                                }
                                <form method="post" asp-page-handler="ToggleFeatured" asp-route-id="@recipe.Id" class="inline">
                                    <input type="hidden" name="p" value="@Model.CurrentPage" />
                                    <input type="hidden" name="PageSize" value="@Model.PageSize" />
                                    <input type="hidden" name="FilterType" value="@Model.FilterType" />
                                    <input type="hidden" name="FilterVisibility" value="@Model.FilterVisibility" />
                                    <input type="hidden" name="Search" value="@Model.Search" />
                                    <button type="submit"
                                        title="@(canFeature ? (recipe.IsFeatured ? "Remove from featured" : "Add to featured") : "Only public user recipes can be featured")"
                                        class="@(recipe.IsFeatured ? "text-amber-500 hover:text-amber-600" : (canFeature ? "text-gray-300 hover:text-amber-400" : "text-gray-200 cursor-not-allowed")) transition-colors"
                                        @(canFeature ? "" : "disabled")>
                                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                        </svg>
                                    </button>
                                </form>
                            </td>
                            <td class="px-4 py-3 text-sm text-gray-500">
                                @recipe.CreatedAt.ToString("MMM dd, yyyy")
                            </td>
                            <td class="px-4 py-3 text-sm text-right">
                                <button type="button"
                                    data-recipe-id="@recipe.Id"
                                    data-recipe-title="@System.Web.HttpUtility.HtmlAttributeEncode(recipe.Title)"
                                    data-recipe-description="@System.Web.HttpUtility.HtmlAttributeEncode(recipe.Description ?? "")"
                                    data-recipe-type="@((int)recipe.Type)"
                                    data-recipe-visibility="@((int)recipe.Visibility)"
                                    data-recipe-difficulty="@((int)recipe.Difficulty)"
                                    @@click="openEditModal($event.currentTarget)"
                                    class="text-blue-600 hover:text-blue-800 font-medium mr-3">
                                    Edit
                                </button>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@recipe.Id"
                                    onsubmit="return confirm('Are you sure you want to delete this recipe? This action cannot be undone.');"
                                    class="inline">
                                    <input type="hidden" name="p" value="@Model.CurrentPage" />
                                    <input type="hidden" name="PageSize" value="@Model.PageSize" />
                                    <input type="hidden" name="FilterType" value="@Model.FilterType" />
                                    <input type="hidden" name="FilterVisibility" value="@Model.FilterVisibility" />
                                    <input type="hidden" name="Search" value="@Model.Search" />
                                    <button type="submit" class="text-red-600 hover:text-red-800 font-medium">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Recipes.Any())
        {
            <div class="p-12 text-center">
                <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
                <p class="mt-2 text-sm text-gray-500">No recipes found matching your filters.</p>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <div class="mt-4 flex flex-col sm:flex-row justify-between items-center gap-4">
            <div class="text-sm text-gray-600">
                Showing @(((Model.CurrentPage - 1) * Model.PageSize) + 1) - @Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalRecipes) of @Model.TotalRecipes recipes
            </div>
            <div class="flex gap-2">
                @if (Model.CurrentPage > 1)
                {
                    <a href="@Url.Page("Index", new { p = Model.CurrentPage - 1, PageSize = Model.PageSize, FilterType = Model.FilterType, FilterVisibility = Model.FilterVisibility, Search = Model.Search })"
                       class="px-4 py-2 bg-white border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
                        Previous
                    </a>
                }
                else
                {
                    <span class="px-4 py-2 bg-gray-100 border border-gray-200 rounded-md text-sm font-medium text-gray-400 cursor-not-allowed">
                        Previous
                    </span>
                }

                <span class="px-4 py-2 text-sm text-gray-600">
                    Page @Model.CurrentPage of @Model.TotalPages
                </span>

                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <a href="@Url.Page("Index", new { p = Model.CurrentPage + 1, PageSize = Model.PageSize, FilterType = Model.FilterType, FilterVisibility = Model.FilterVisibility, Search = Model.Search })"
                       class="px-4 py-2 bg-white border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
                        Next
                    </a>
                }
                else
                {
                    <span class="px-4 py-2 bg-gray-100 border border-gray-200 rounded-md text-sm font-medium text-gray-400 cursor-not-allowed">
                        Next
                    </span>
                }
            </div>
        </div>
    }

    <!-- Edit Modal -->
    <div x-show="showEditModal" style="display: none;" class="fixed inset-0 z-50 flex items-center justify-center p-4" x-cloak>
        <div class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm" @@click="showEditModal = false"></div>
        <div class="relative bg-white rounded-xl shadow-xl max-w-lg w-full p-6 z-10">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Edit Recipe</h3>
            <form method="post" asp-page-handler="Edit">
                <input type="hidden" asp-for="EditId" x-model="editId" />
                <input type="hidden" name="p" value="@Model.CurrentPage" />
                <input type="hidden" name="PageSize" value="@Model.PageSize" />
                <input type="hidden" name="FilterType" value="@Model.FilterType" />
                <input type="hidden" name="FilterVisibility" value="@Model.FilterVisibility" />
                <input type="hidden" name="Search" value="@Model.Search" />

                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Title</label>
                        <input asp-for="EditRecipe.Title" x-model="editTitle"
                            class="w-full border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border"
                            required />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Description (optional)</label>
                        <textarea asp-for="EditRecipe.Description" x-model="editDescription" rows="3"
                            class="w-full border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border"></textarea>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Type</label>
                            <select asp-for="EditRecipe.Type" x-model="editType"
                                class="w-full border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border">
                                <option value="@((int)RecipeType.User)">User</option>
                                <option value="@((int)RecipeType.System)">System</option>
                                <option value="@((int)RecipeType.Model)">Model (AI)</option>
                            </select>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Visibility</label>
                            <select asp-for="EditRecipe.Visibility" x-model="editVisibility"
                                class="w-full border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border">
                                <option value="@((int)RecipeVisibility.Private)">Private</option>
                                <option value="@((int)RecipeVisibility.Public)">Public</option>
                            </select>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Difficulty</label>
                        <select asp-for="EditRecipe.Difficulty" x-model="editDifficulty"
                            class="w-full border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border">
                            <option value="@((int)RecipeDifficulty.None)">None</option>
                            <option value="@((int)RecipeDifficulty.Easy)">Easy</option>
                            <option value="@((int)RecipeDifficulty.Medium)">Medium</option>
                            <option value="@((int)RecipeDifficulty.Hard)">Hard</option>
                        </select>
                    </div>
                </div>

                <div class="flex justify-end gap-3 mt-6">
                    <button type="button" @@click="showEditModal = false"
                        class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-md transition-colors">
                        Cancel
                    </button>
                    <button type="submit"
                        class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-md transition-colors">
                        Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
