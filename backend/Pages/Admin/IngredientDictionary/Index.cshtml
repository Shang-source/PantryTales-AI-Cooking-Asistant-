@page
@model backend.Pages.Admin.IngredientDictionary.IndexModel
@{
    ViewData["Title"] = "Ingredient Dictionary";
    Layout = "_AdminLayout";
}

<div x-data="{
        showAddTagModal: false,
        addTagIngredientId: '',
        addTagIngredientName: '',
        selectedTagId: '',
        openAddTagModal(ingredientId, ingredientName) {
            this.addTagIngredientId = ingredientId;
            this.addTagIngredientName = ingredientName;
            this.selectedTagId = '';
            this.showAddTagModal = true;
        }
    }">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
        <div>
            <h2 class="text-2xl font-bold text-gray-900">Ingredient Dictionary</h2>
            <p class="text-sm text-gray-600 mt-1">Manage canonical ingredients and their tag mappings</p>
        </div>
        <div class="text-sm text-gray-500">
            @Model.TotalIngredients ingredients total
        </div>
    </div>

    <!-- Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="mb-4 flex items-center gap-3 p-4 bg-green-50 border border-green-200 rounded-lg">
            <svg class="w-5 h-5 text-green-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm text-green-800">@TempData["Success"]</span>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="mb-4 flex items-center gap-3 p-4 bg-red-50 border border-red-200 rounded-lg">
            <svg class="w-5 h-5 text-red-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm text-red-800">@TempData["Error"]</span>
        </div>
    }

    <!-- Filters -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 mb-6">
        <form method="get" class="flex flex-wrap gap-4 items-end">
            <div class="flex-1 min-w-[200px]">
                <label class="block text-sm font-medium text-gray-700 mb-1">Search</label>
                <input type="text" name="Search" value="@Model.Search"
                    placeholder="Search by name..."
                    class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:ring-blue-500 focus:border-blue-500" />
            </div>
            <div class="w-48">
                <label class="block text-sm font-medium text-gray-700 mb-1">Filter by Tag</label>
                <select name="FilterTagId" class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:ring-blue-500 focus:border-blue-500">
                    <option value="">All Tags</option>
                    @foreach (var tagType in Model.TagTypes)
                    {
                        var tagsOfType = Model.AvailableTags.Where(t => t.Type == tagType.Name).ToList();
                        if (tagsOfType.Any())
                        {
                            <optgroup label="@tagType.DisplayName">
                                @foreach (var tag in tagsOfType)
                                {
                                    <option value="@tag.Id" selected="@(Model.FilterTagId == tag.Id)">@tag.DisplayName</option>
                                }
                            </optgroup>
                        }
                    }
                    @{
                        var uncategorizedTags = Model.AvailableTags.Where(t => !Model.TagTypes.Any(tt => tt.Name == t.Type)).ToList();
                        if (uncategorizedTags.Any())
                        {
                            <optgroup label="Other">
                                @foreach (var tag in uncategorizedTags)
                                {
                                    <option value="@tag.Id" selected="@(Model.FilterTagId == tag.Id)">@tag.DisplayName (@tag.Type)</option>
                                }
                            </optgroup>
                        }
                    }
                </select>
            </div>
            <div class="flex items-center gap-2">
                <input type="checkbox" id="showUntagged" name="ShowUntagged" value="true" checked="@Model.ShowUntagged"
                    class="h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" />
                <label for="showUntagged" class="text-sm text-gray-700">Show untagged only</label>
            </div>
            <div class="w-32">
                <label class="block text-sm font-medium text-gray-700 mb-1">Per page</label>
                <select name="PageSize" class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:ring-blue-500 focus:border-blue-500">
                    <option value="10" selected="@(Model.PageSize == 10)">10</option>
                    <option value="20" selected="@(Model.PageSize == 20)">20</option>
                    <option value="50" selected="@(Model.PageSize == 50)">50</option>
                    <option value="100" selected="@(Model.PageSize == 100)">100</option>
                </select>
            </div>
            <button type="submit" class="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700 transition-colors">
                Apply Filters
            </button>
            @if (!string.IsNullOrEmpty(Model.Search) || Model.FilterTagId.HasValue || Model.ShowUntagged)
            {
                <a href="/Admin/IngredientDictionary" class="px-4 py-2 text-gray-600 text-sm font-medium hover:text-gray-900">
                    Clear
                </a>
            }
        </form>
    </div>

    <!-- Ingredients Table -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Ingredient</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tags</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Recipes</th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                @if (Model.Ingredients.Count == 0)
                {
                    <tr>
                        <td colspan="4" class="px-6 py-8 text-center text-gray-500">
                            No ingredients found matching your criteria.
                        </td>
                    </tr>
                }
                @foreach (var ingredient in Model.Ingredients)
                {
                    <tr class="hover:bg-gray-50">
                        <td class="px-6 py-4">
                            <div class="font-medium text-gray-900">@ingredient.CanonicalName</div>
                            @if (!string.IsNullOrEmpty(ingredient.DefaultUnit))
                            {
                                <div class="text-sm text-gray-500">Default unit: @ingredient.DefaultUnit</div>
                            }
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex flex-wrap gap-1">
                                @foreach (var tag in ingredient.Tags)
                                {
                                    <span class="inline-flex items-center gap-1 px-2 py-1 rounded text-xs font-medium"
                                          style="background-color: @(tag.Color ?? "#e5e7eb"); color: @(GetContrastColor(tag.Color))">
                                        @tag.DisplayName
                                        <form method="post" asp-page-handler="RemoveTag" class="inline">
                                            <input type="hidden" name="RemoveTagIngredientId" value="@ingredient.Id" />
                                            <input type="hidden" name="RemoveTagId" value="@tag.Id" />
                                            <input type="hidden" name="p" value="@Model.CurrentPage" />
                                            <input type="hidden" name="PageSize" value="@Model.PageSize" />
                                            <input type="hidden" name="Search" value="@Model.Search" />
                                            <input type="hidden" name="FilterTagId" value="@Model.FilterTagId" />
                                            <input type="hidden" name="ShowUntagged" value="@Model.ShowUntagged" />
                                            <button type="submit" class="hover:opacity-70" title="Remove tag">
                                                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                                                    <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                                                </svg>
                                            </button>
                                        </form>
                                    </span>
                                }
                                @if (ingredient.Tags.Count == 0)
                                {
                                    <span class="text-sm text-gray-400 italic">No tags</span>
                                }
                            </div>
                        </td>
                        <td class="px-6 py-4 text-sm text-gray-500">
                            @ingredient.RecipeCount
                        </td>
                        <td class="px-6 py-4 text-right">
                            <button type="button"
                                    @@click="openAddTagModal('@ingredient.Id', '@ingredient.CanonicalName.Replace("'", "\\'")' )"
                                    class="text-blue-600 hover:text-blue-800 text-sm font-medium">
                                Add Tag
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <div class="mt-4 flex items-center justify-between">
            <div class="text-sm text-gray-500">
                Showing @((Model.CurrentPage - 1) * Model.PageSize + 1) to @Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalIngredients) of @Model.TotalIngredients ingredients
            </div>
            <div class="flex gap-2">
                @if (Model.CurrentPage > 1)
                {
                    <a href="?p=@(Model.CurrentPage - 1)&PageSize=@Model.PageSize&Search=@Model.Search&FilterTagId=@Model.FilterTagId&ShowUntagged=@Model.ShowUntagged"
                       class="px-3 py-2 border border-gray-300 rounded-md text-sm text-gray-700 hover:bg-gray-50">
                        Previous
                    </a>
                }
                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <a href="?p=@(Model.CurrentPage + 1)&PageSize=@Model.PageSize&Search=@Model.Search&FilterTagId=@Model.FilterTagId&ShowUntagged=@Model.ShowUntagged"
                       class="px-3 py-2 border border-gray-300 rounded-md text-sm text-gray-700 hover:bg-gray-50">
                        Next
                    </a>
                }
            </div>
        </div>
    }

    <!-- Add Tag Modal -->
    <div x-show="showAddTagModal" x-cloak class="fixed inset-0 z-50 overflow-y-auto" aria-modal="true">
        <div class="flex items-center justify-center min-h-screen px-4">
            <div class="fixed inset-0 bg-gray-500 bg-opacity-75" @@click="showAddTagModal = false"></div>
            <div class="relative bg-white rounded-lg shadow-xl max-w-md w-full p-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-4">Add Tag to Ingredient</h3>
                <p class="text-sm text-gray-600 mb-4">Adding tag to: <span class="font-medium" x-text="addTagIngredientName"></span></p>

                <form method="post" asp-page-handler="AddTag">
                    <input type="hidden" name="AddTagIngredientId" x-bind:value="addTagIngredientId" />
                    <input type="hidden" name="p" value="@Model.CurrentPage" />
                    <input type="hidden" name="PageSize" value="@Model.PageSize" />
                    <input type="hidden" name="Search" value="@Model.Search" />
                    <input type="hidden" name="FilterTagId" value="@Model.FilterTagId" />
                    <input type="hidden" name="ShowUntagged" value="@Model.ShowUntagged" />

                    <div class="mb-4">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Select Tag</label>
                        <select name="AddTagId" x-model="selectedTagId" required
                                class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:ring-blue-500 focus:border-blue-500">
                            <option value="">Choose a tag...</option>
                            @foreach (var tagType in Model.TagTypes)
                            {
                                var tagsOfType = Model.AvailableTags.Where(t => t.Type == tagType.Name).ToList();
                                if (tagsOfType.Any())
                                {
                                    <optgroup label="@tagType.DisplayName">
                                        @foreach (var tag in tagsOfType)
                                        {
                                            <option value="@tag.Id">@tag.DisplayName</option>
                                        }
                                    </optgroup>
                                }
                            }
                            @{
                                var otherTags = Model.AvailableTags.Where(t => !Model.TagTypes.Any(tt => tt.Name == t.Type)).ToList();
                                if (otherTags.Any())
                                {
                                    <optgroup label="Other">
                                        @foreach (var tag in otherTags)
                                        {
                                            <option value="@tag.Id">@tag.DisplayName (@tag.Type)</option>
                                        }
                                    </optgroup>
                                }
                            }
                        </select>
                    </div>

                    <div class="flex justify-end gap-3">
                        <button type="button" @@click="showAddTagModal = false"
                                class="px-4 py-2 text-sm font-medium text-gray-700 hover:text-gray-900">
                            Cancel
                        </button>
                        <button type="submit"
                                class="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700 transition-colors">
                            Add Tag
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@functions {
    private static string GetContrastColor(string? hexColor)
    {
        if (string.IsNullOrEmpty(hexColor) || !hexColor.StartsWith("#") || hexColor.Length < 7)
            return "#374151"; // Default dark gray

        try
        {
            var r = Convert.ToInt32(hexColor.Substring(1, 2), 16);
            var g = Convert.ToInt32(hexColor.Substring(3, 2), 16);
            var b = Convert.ToInt32(hexColor.Substring(5, 2), 16);
            var luminance = (0.299 * r + 0.587 * g + 0.114 * b) / 255;
            return luminance > 0.5 ? "#1f2937" : "#ffffff";
        }
        catch
        {
            return "#374151";
        }
    }
}
