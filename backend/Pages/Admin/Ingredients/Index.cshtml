@page
@using backend.Models
@model backend.Pages.Admin.Ingredients.IndexModel
@{
    ViewData["Title"] = "Ingredient Resolution";
}

<div x-data="{
        showLinkModal: false,
        showCreateModal: false,
        showTokenModal: false,
        linkNormalizedName: '',
        createCanonicalName: '',
        newToken: '',
        openLinkModal(normalizedName) {
            this.linkNormalizedName = normalizedName;
            this.showLinkModal = true;
        },
        openCreateModal(normalizedName) {
            this.createCanonicalName = normalizedName;
            this.showCreateModal = true;
        },
        openTokenModal(token) {
            this.newToken = token;
            this.showTokenModal = true;
        }
    }">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
        <div>
            <h2 class="text-2xl font-bold text-gray-900">Ingredient Resolution</h2>
            <p class="text-sm text-gray-600 mt-1">Review and resolve ingredient normalization</p>
        </div>
        <form method="post" asp-page-handler="SuggestTokens">
            <input type="hidden" name="p" value="@Model.CurrentPage" />
            <input type="hidden" name="PageSize" value="@Model.PageSize" />
            <input type="hidden" name="FilterStatus" value="@Model.FilterStatus" />
            <input type="hidden" name="Search" value="@Model.Search" />
            <input type="hidden" name="ShowResolved" value="@Model.ShowResolved" />
            <button type="submit"
                class="inline-flex items-center px-4 py-2 bg-purple-600 hover:bg-purple-700 text-white text-sm font-medium rounded-md transition-colors">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                </svg>
                AI Suggest Tokens
            </button>
        </form>
    </div>

    <!-- Summary Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4">
            <div class="text-2xl font-bold text-yellow-600">@Model.PendingCount</div>
            <div class="text-sm text-gray-600">Pending</div>
        </div>
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4">
            <div class="text-2xl font-bold text-orange-600">@Model.NeedsReviewCount</div>
            <div class="text-sm text-gray-600">Needs Review</div>
        </div>
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4">
            <div class="text-2xl font-bold text-red-600">@Model.FailedCount</div>
            <div class="text-sm text-gray-600">Failed</div>
        </div>
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4">
            <div class="text-2xl font-bold text-green-600">@Model.ResolvedCount</div>
            <div class="text-sm text-gray-600">Resolved</div>
        </div>
    </div>

    <!-- Filters -->
    <div class="mb-4 bg-white rounded-lg shadow-sm border border-gray-200 p-4">
        <form method="get" class="flex flex-wrap items-end gap-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
                <select name="filterStatus"
                    class="border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border">
                    <option value="">All Unresolved</option>
                    <option value="@((int)IngredientResolveStatus.Pending)" selected="@(Model.FilterStatus == IngredientResolveStatus.Pending)">Pending</option>
                    <option value="@((int)IngredientResolveStatus.NeedsReview)" selected="@(Model.FilterStatus == IngredientResolveStatus.NeedsReview)">Needs Review</option>
                    <option value="@((int)IngredientResolveStatus.Failed)" selected="@(Model.FilterStatus == IngredientResolveStatus.Failed)">Failed</option>
                    <option value="@((int)IngredientResolveStatus.Resolved)" selected="@(Model.FilterStatus == IngredientResolveStatus.Resolved)">Resolved</option>
                </select>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Search</label>
                <input type="text" name="search" value="@Model.Search" placeholder="Search names..."
                    class="border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border" />
            </div>

            <div class="flex items-center">
                <input type="checkbox" name="showResolved" value="true" id="showResolved" checked="@Model.ShowResolved"
                    class="h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" />
                <label for="showResolved" class="ml-2 text-sm text-gray-700">Include resolved</label>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Page Size</label>
                <select name="pageSize"
                    class="border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border">
                    <option value="10" selected="@(Model.PageSize == 10)">10</option>
                    <option value="20" selected="@(Model.PageSize == 20)">20</option>
                    <option value="50" selected="@(Model.PageSize == 50)">50</option>
                    <option value="100" selected="@(Model.PageSize == 100)">100</option>
                </select>
            </div>

            <button type="submit"
                class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-md transition-colors">
                Apply Filters
            </button>

            @if (Model.FilterStatus.HasValue || !string.IsNullOrEmpty(Model.Search) || Model.ShowResolved)
            {
                <a href="/Admin/Ingredients"
                    class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-md transition-colors">
                    Clear Filters
                </a>
            }
        </form>
    </div>

    <!-- Messages -->
    @if (TempData["Success"] != null)
    {
        <div class="mb-4 flex items-center gap-3 p-4 bg-green-50 border border-green-200 rounded-lg">
            <svg class="w-5 h-5 text-green-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm text-green-800">@TempData["Success"]</span>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="mb-4 flex items-center gap-3 p-4 bg-red-50 border border-red-200 rounded-lg">
            <svg class="w-5 h-5 text-red-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm text-red-800">@TempData["Error"]</span>
        </div>
    }
    @if (TempData["Info"] != null)
    {
        <div class="mb-4 flex items-center gap-3 p-4 bg-blue-50 border border-blue-200 rounded-lg">
            <svg class="w-5 h-5 text-blue-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm text-blue-800">@TempData["Info"]</span>
        </div>
    }

    <!-- AI Suggestions -->
    @if (Model.AISuggestions.Any())
    {
        <div class="mb-6 bg-purple-50 rounded-lg border border-purple-200 overflow-hidden">
            <div class="px-4 py-3 bg-purple-100 border-b border-purple-200">
                <div class="flex items-center gap-2">
                    <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                    </svg>
                    <span class="font-medium text-purple-800">AI Suggested Tokens</span>
                    <span class="text-sm text-purple-600">(@Model.AISuggestions.Count suggestions)</span>
                </div>
            </div>
            <div class="p-4">
                <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
                    @foreach (var suggestion in Model.AISuggestions)
                    {
                        <div class="bg-white rounded-lg border border-purple-100 p-3">
                            <div class="flex items-start justify-between gap-2 mb-2">
                                <span class="font-mono text-sm font-medium text-gray-900">@suggestion.Token</span>
                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-purple-100 text-purple-800">
                                    @suggestion.Category
                                </span>
                            </div>
                            <p class="text-xs text-gray-600 mb-2">@suggestion.Reason</p>
                            @if (suggestion.Examples.Any())
                            {
                                <div class="text-xs text-gray-500 truncate" title="@string.Join(", ", suggestion.Examples)">
                                    e.g., @string.Join(", ", suggestion.Examples.Take(2))
                                </div>
                            }
                            <form method="post" asp-page-handler="AddToken" class="mt-2">
                                <input type="hidden" asp-for="NewToken" value="@suggestion.Token" />
                                <input type="hidden" asp-for="NewTokenCategory" value="@suggestion.Category" />
                                <input type="hidden" name="p" value="@Model.CurrentPage" />
                                <input type="hidden" name="PageSize" value="@Model.PageSize" />
                                <input type="hidden" name="FilterStatus" value="@Model.FilterStatus" />
                                <input type="hidden" name="Search" value="@Model.Search" />
                                <input type="hidden" name="ShowResolved" value="@Model.ShowResolved" />
                                <button type="submit"
                                    class="w-full px-2 py-1 bg-purple-600 hover:bg-purple-700 text-white text-xs font-medium rounded transition-colors">
                                    Add Token
                                </button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- Ingredient Groups -->
    <div class="space-y-4">
        @foreach (var group in Model.Groups)
        {
            <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
                <div class="p-4 border-b border-gray-100 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
                    <!-- Group Header -->
                    <div class="flex-1">
                        <div class="flex items-center gap-2 mb-1">
                            <span class="text-lg font-semibold text-gray-900">@group.NormalizedName</span>
                            <span class="text-sm text-gray-500">(@group.TotalCount items)</span>
                        </div>
                        @if (group.IngredientId.HasValue)
                        {
                            <div class="text-sm text-green-600 flex items-center gap-1">
                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                                </svg>
                                Linked to: <strong>@group.IngredientCanonicalName</strong>
                            </div>
                        }
                        else
                        {
                            <div class="text-sm text-orange-600">Not linked to any ingredient</div>
                        }
                    </div>

                    <!-- Status badges -->
                    <div class="flex items-center gap-2 flex-wrap">
                        @if (group.PendingCount > 0)
                        {
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                                @group.PendingCount Pending
                            </span>
                        }
                        @if (group.NeedsReviewCount > 0)
                        {
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-orange-100 text-orange-800">
                                @group.NeedsReviewCount Review
                            </span>
                        }
                        @if (group.FailedCount > 0)
                        {
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                @group.FailedCount Failed
                            </span>
                        }
                        @if (group.ResolvedCount > 0)
                        {
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                @group.ResolvedCount Resolved
                            </span>
                        }
                    </div>

                    <!-- Actions -->
                    <div class="flex items-center gap-2">
                        <button type="button"
                            @@click="openLinkModal('@System.Web.HttpUtility.JavaScriptStringEncode(group.NormalizedName)')"
                            class="px-3 py-1.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded transition-colors">
                            Link
                        </button>
                        @if (!group.IngredientId.HasValue)
                        {
                            <button type="button"
                                @@click="openCreateModal('@System.Web.HttpUtility.JavaScriptStringEncode(group.NormalizedName)')"
                                class="px-3 py-1.5 bg-green-600 hover:bg-green-700 text-white text-sm font-medium rounded transition-colors">
                                Create
                            </button>
                        }
                    </div>
                </div>

                <!-- Sample raw names -->
                <div class="px-4 py-3 bg-gray-50">
                    <div class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-2">Sample Raw Names</div>
                    <div class="flex flex-wrap gap-2">
                        @foreach (var rawName in group.SampleRawNames)
                        {
                            <span class="inline-flex items-center px-2 py-1 rounded text-xs bg-white border border-gray-200 text-gray-700 font-mono">
                                @rawName
                            </span>
                        }
                    </div>
                </div>

                <!-- Removed tokens -->
                @if (group.RemovedTokens.Any())
                {
                    <div class="px-4 py-3 border-t border-gray-100">
                        <div class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-2">Removed Tokens (click to add to dictionary)</div>
                        <div class="flex flex-wrap gap-2">
                            @foreach (var token in group.RemovedTokens)
                            {
                                <button type="button"
                                    @@click="openTokenModal('@System.Web.HttpUtility.JavaScriptStringEncode(token)')"
                                    class="inline-flex items-center px-2 py-1 rounded text-xs bg-purple-50 border border-purple-200 text-purple-700 hover:bg-purple-100 transition-colors cursor-pointer">
                                    <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                                    </svg>
                                    @token
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    @if (!Model.Groups.Any())
    {
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-12 text-center">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p class="mt-2 text-sm text-gray-500">No ingredient groups found matching your filters.</p>
        </div>
    }

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <div class="mt-4 flex flex-col sm:flex-row justify-between items-center gap-4">
            <div class="text-sm text-gray-600">
                Showing @(((Model.CurrentPage - 1) * Model.PageSize) + 1) - @Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalGroups) of @Model.TotalGroups groups
            </div>
            <div class="flex gap-2">
                @if (Model.CurrentPage > 1)
                {
                    <a href="@Url.Page("Index", new { p = Model.CurrentPage - 1, PageSize = Model.PageSize, FilterStatus = Model.FilterStatus, Search = Model.Search, ShowResolved = Model.ShowResolved })"
                        class="px-4 py-2 bg-white border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
                        Previous
                    </a>
                }
                else
                {
                    <span class="px-4 py-2 bg-gray-100 border border-gray-200 rounded-md text-sm font-medium text-gray-400 cursor-not-allowed">
                        Previous
                    </span>
                }

                <span class="px-4 py-2 text-sm text-gray-600">
                    Page @Model.CurrentPage of @Model.TotalPages
                </span>

                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <a href="@Url.Page("Index", new { p = Model.CurrentPage + 1, PageSize = Model.PageSize, FilterStatus = Model.FilterStatus, Search = Model.Search, ShowResolved = Model.ShowResolved })"
                        class="px-4 py-2 bg-white border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
                        Next
                    </a>
                }
                else
                {
                    <span class="px-4 py-2 bg-gray-100 border border-gray-200 rounded-md text-sm font-medium text-gray-400 cursor-not-allowed">
                        Next
                    </span>
                }
            </div>
        </div>
    }

    <!-- Link Modal -->
    <div x-show="showLinkModal" style="display: none;" class="fixed inset-0 z-50 flex items-center justify-center p-4" x-cloak>
        <div class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm" @@click="showLinkModal = false"></div>
        <div class="relative bg-white rounded-xl shadow-xl max-w-lg w-full p-6 z-10">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Link to Existing Ingredient</h3>
            <form method="post" asp-page-handler="Link">
                <input type="hidden" asp-for="LinkNormalizedName" x-model="linkNormalizedName" />
                <input type="hidden" name="p" value="@Model.CurrentPage" />
                <input type="hidden" name="PageSize" value="@Model.PageSize" />
                <input type="hidden" name="FilterStatus" value="@Model.FilterStatus" />
                <input type="hidden" name="Search" value="@Model.Search" />
                <input type="hidden" name="ShowResolved" value="@Model.ShowResolved" />

                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Normalized Name</label>
                        <input type="text" x-model="linkNormalizedName" readonly
                            class="w-full border-gray-300 rounded-md shadow-sm bg-gray-50 text-sm py-2 px-3 border" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Select Ingredient</label>
                        <select asp-for="LinkIngredientId"
                            class="w-full border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border">
                            <option value="">Select an ingredient...</option>
                            @foreach (var ingredient in Model.AllIngredients)
                            {
                                <option value="@ingredient.Id">@ingredient.CanonicalName</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="flex justify-end gap-3 mt-6">
                    <button type="button" @@click="showLinkModal = false"
                        class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-md transition-colors">
                        Cancel
                    </button>
                    <button type="submit"
                        class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-md transition-colors">
                        Link Items
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Create Modal -->
    <div x-show="showCreateModal" style="display: none;" class="fixed inset-0 z-50 flex items-center justify-center p-4" x-cloak>
        <div class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm" @@click="showCreateModal = false"></div>
        <div class="relative bg-white rounded-xl shadow-xl max-w-lg w-full p-6 z-10">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Create New Ingredient</h3>
            <form method="post" asp-page-handler="CreateIngredient">
                <input type="hidden" asp-for="CreateCanonicalName" x-model="createCanonicalName" />
                <input type="hidden" name="p" value="@Model.CurrentPage" />
                <input type="hidden" name="PageSize" value="@Model.PageSize" />
                <input type="hidden" name="FilterStatus" value="@Model.FilterStatus" />
                <input type="hidden" name="Search" value="@Model.Search" />
                <input type="hidden" name="ShowResolved" value="@Model.ShowResolved" />

                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Canonical Name</label>
                        <input type="text" x-model="createCanonicalName"
                            class="w-full border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border"
                            placeholder="e.g., milk" />
                        <p class="mt-1 text-xs text-gray-500">The standardized name for this ingredient (will be lowercased).</p>
                    </div>
                </div>

                <div class="flex justify-end gap-3 mt-6">
                    <button type="button" @@click="showCreateModal = false"
                        class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-md transition-colors">
                        Cancel
                    </button>
                    <button type="submit"
                        class="px-4 py-2 bg-green-600 hover:bg-green-700 text-white text-sm font-medium rounded-md transition-colors">
                        Create & Link
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Add Token Modal -->
    <div x-show="showTokenModal" style="display: none;" class="fixed inset-0 z-50 flex items-center justify-center p-4" x-cloak>
        <div class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm" @@click="showTokenModal = false"></div>
        <div class="relative bg-white rounded-xl shadow-xl max-w-lg w-full p-6 z-10">
            <h3 class="text-lg font-semibold text-gray-900 mb-4">Add Normalization Token</h3>
            <form method="post" asp-page-handler="AddToken">
                <input type="hidden" asp-for="NewToken" x-model="newToken" />
                <input type="hidden" name="p" value="@Model.CurrentPage" />
                <input type="hidden" name="PageSize" value="@Model.PageSize" />
                <input type="hidden" name="FilterStatus" value="@Model.FilterStatus" />
                <input type="hidden" name="Search" value="@Model.Search" />
                <input type="hidden" name="ShowResolved" value="@Model.ShowResolved" />

                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Token</label>
                        <input type="text" x-model="newToken"
                            class="w-full border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Category</label>
                        <select asp-for="NewTokenCategory" asp-items="Html.GetEnumSelectList<NameNormalizationTokenCategory>()"
                            class="w-full border-gray-300 rounded-md shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border">
                        </select>
                    </div>

                    <p class="text-xs text-gray-500">
                        Adding this token will cause items to be re-normalized on the next background run,
                        which may change their normalized names.
                    </p>
                </div>

                <div class="flex justify-end gap-3 mt-6">
                    <button type="button" @@click="showTokenModal = false"
                        class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium rounded-md transition-colors">
                        Cancel
                    </button>
                    <button type="submit"
                        class="px-4 py-2 bg-purple-600 hover:bg-purple-700 text-white text-sm font-medium rounded-md transition-colors">
                        Add Token
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
