<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PantryTales Admin</title>
    <script src="https://cdn.tailwindcss.com/3.4.1"></script>
    <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.3/dist/cdn.min.js" defer></script>
    <style>
        [x-cloak] {
            display: none !important;
        }
    </style>
</head>

<body class="bg-gray-50 font-sans leading-normal tracking-normal">
    <div class="flex flex-col md:flex-row min-h-screen">
        <!-- Sidebar -->
        <div class="bg-white border-r border-gray-200 shadow-sm md:fixed md:left-0 md:top-0 md:h-screen md:w-64 z-20 w-full">
            <div class="flex flex-col h-full">
                <!-- Logo -->
                <div class="p-6 border-b border-gray-200">
                    <h1 class="text-xl font-bold text-gray-900">PantryTales Admin</h1>
                </div>

                <!-- Navigation -->
                <nav class="flex-1 overflow-y-auto p-4">
                    <ul class="space-y-1">
                        <li>
                            <a href="/Admin"
                               class="flex items-center px-4 py-3 text-sm font-medium rounded-lg transition-colors @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("/Admin/Index") == true || ViewContext.RouteData.Values["page"]?.ToString() == "/Admin/Index" || ViewContext.RouteData.Values["page"] == null ? "bg-blue-50 text-blue-600" : "text-gray-600 hover:bg-gray-50 hover:text-gray-900")">
                                Dashboard
                            </a>
                        </li>
                        <li>
                            <a href="/Admin/Ingredients"
                               class="flex items-center px-4 py-3 text-sm font-medium rounded-lg transition-colors @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("/Ingredients") == true && !ViewContext.RouteData.Values["page"]?.ToString()?.Contains("IngredientDictionary") == true ? "bg-blue-50 text-blue-600" : "text-gray-600 hover:bg-gray-50 hover:text-gray-900")">
                                Pantry Resolution
                            </a>
                        </li>
                        <li>
                            <a href="/Admin/IngredientDictionary"
                               class="flex items-center px-4 py-3 text-sm font-medium rounded-lg transition-colors @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("IngredientDictionary") == true ? "bg-blue-50 text-blue-600" : "text-gray-600 hover:bg-gray-50 hover:text-gray-900")">
                                Ingredient Dictionary
                            </a>
                        </li>
                        <li>
                            <a href="/Admin/Normalization"
                               class="flex items-center px-4 py-3 text-sm font-medium rounded-lg transition-colors @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Normalization") == true ? "bg-blue-50 text-blue-600" : "text-gray-600 hover:bg-gray-50 hover:text-gray-900")">
                                Tokens
                            </a>
                        </li>
                        <li>
                            <a href="/Admin/Tags"
                               class="flex items-center px-4 py-3 text-sm font-medium rounded-lg transition-colors @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Tags") == true && !ViewContext.RouteData.Values["page"]?.ToString()?.Contains("TagTypes") == true ? "bg-blue-50 text-blue-600" : "text-gray-600 hover:bg-gray-50 hover:text-gray-900")">
                                Tags
                            </a>
                        </li>
                        <li>
                            <a href="/Admin/Recipes"
                               class="flex items-center px-4 py-3 text-sm font-medium rounded-lg transition-colors @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Recipes") == true ? "bg-blue-50 text-blue-600" : "text-gray-600 hover:bg-gray-50 hover:text-gray-900")">
                                Recipes
                            </a>
                        </li>
                        <li>
                            <a href="/Admin/TagTypes"
                               class="flex items-center px-4 py-3 text-sm font-medium rounded-lg transition-colors @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("TagTypes") == true ? "bg-blue-50 text-blue-600" : "text-gray-600 hover:bg-gray-50 hover:text-gray-900")">
                                Tag Types
                            </a>
                        </li>
                        <li>
                            <a href="/Admin/Jobs"
                               class="flex items-center px-4 py-3 text-sm font-medium rounded-lg transition-colors @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Jobs") == true ? "bg-blue-50 text-blue-600" : "text-gray-600 hover:bg-gray-50 hover:text-gray-900")">
                                Jobs
                            </a>
                        </li>
                        <li>
                            <a href="/Admin/Knowledgebase"
                               class="flex items-center px-4 py-3 text-sm font-medium rounded-lg transition-colors @(ViewContext.RouteData.Values["page"]?.ToString()?.Contains("Knowledgebase") == true ? "bg-blue-50 text-blue-600" : "text-gray-600 hover:bg-gray-50 hover:text-gray-900")">
                                Knowledge Base
                            </a>
                        </li>
                    </ul>
                </nav>

                <!-- Logout -->
                <div class="p-4 border-t border-gray-200">
                    <form method="post" asp-page="/Admin/Logout">
                        <button type="submit"
                                class="flex items-center w-full px-4 py-3 text-sm font-medium text-gray-600 rounded-lg hover:bg-gray-50 hover:text-gray-900 transition-colors">
                            <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                            </svg>
                            Logout
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="flex-1 md:ml-64">
            <!-- Header -->
            <header class="bg-white border-b border-gray-200 sticky top-0 z-10">
                <div class="px-6 py-4">
                    <h1 class="text-2xl font-bold text-gray-900">@ViewData["Title"]</h1>
                </div>
            </header>

            <!-- Page Content -->
            <main class="p-6">
                @RenderBody()
            </main>
        </div>
    </div>
</body>

</html>
