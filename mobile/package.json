    "@types/react": "~19.1.17",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^9.39.2",
    "eslint-config-expo": "~10.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.16",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "react-test-renderer": "^19.2.3",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3"
  },
  "private": true
}
